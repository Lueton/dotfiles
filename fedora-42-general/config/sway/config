# Sway config — Modifier: Super (Mod4)
set $mod Mod4

font pango:JetBrainsMono Nerd Font 10

# Pywal colors (generated by 'wallpaper' command)
include ~/.cache/wal/colors.sway

# Applications
set $term   kitty
set $menu   wofi --show drun

# ── Launch ────────────────────────────────────────────────
bindsym $mod+Return       exec $term
bindsym $mod+d            exec pgrep -x wofi > /dev/null || $menu
bindsym $mod+Shift+b      exec firefox
bindsym $mod+Shift+n      exec nemo
bindsym $mod+question     exec sway-keybinds

# Kill focused window
bindsym $mod+Shift+q kill

# ── Focus (vim keys + arrows) ─────────────────────────────
bindsym $mod+h     focus left
bindsym $mod+j     focus down
bindsym $mod+k     focus up
bindsym $mod+l     focus right
bindsym $mod+Left  focus left
bindsym $mod+Down  focus down
bindsym $mod+Up    focus up
bindsym $mod+Right focus right

# ── Move ─────────────────────────────────────────────────
bindsym $mod+Shift+h     move left
bindsym $mod+Shift+j     move down
bindsym $mod+Shift+k     move up
bindsym $mod+Shift+l     move right
bindsym $mod+Shift+Left  move left
bindsym $mod+Shift+Down  move down
bindsym $mod+Shift+Up    move up
bindsym $mod+Shift+Right move right

# ── Splits ───────────────────────────────────────────────
bindsym $mod+backslash split h
bindsym $mod+minus     split v

# ── Layout ───────────────────────────────────────────────
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen toggle

bindsym $mod+Shift+space floating toggle
bindsym $mod+space       focus mode_toggle
bindsym $mod+a           focus parent

# ── Workspaces ───────────────────────────────────────────
set $ws1  "1"
set $ws2  "2"
set $ws3  "3"
set $ws4  "4"
set $ws5  "5"
set $ws6  "6"
set $ws7  "7"
set $ws8  "8"
set $ws9  "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Cycle workspaces on the currently focused output only
bindsym $mod+Tab       workspace next_on_output
bindsym $mod+Shift+Tab workspace prev_on_output

# ── Resize mode ──────────────────────────────────────────
mode "resize" {
    bindsym h     resize shrink width  10 px or 10 ppt
    bindsym l     resize grow   width  10 px or 10 ppt
    bindsym k     resize shrink height 10 px or 10 ppt
    bindsym j     resize grow   height 10 px or 10 ppt
    bindsym Left  resize shrink width  10 px or 10 ppt
    bindsym Right resize grow   width  10 px or 10 ppt
    bindsym Up    resize shrink height 10 px or 10 ppt
    bindsym Down  resize grow   height 10 px or 10 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# ── System ───────────────────────────────────────────────
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+x exec swaylock
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit sway?' -B 'Yes, exit' 'swaymsg exit'

# Screenshot
bindsym Print       exec grim "$HOME/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png" && notify-send "Screenshot saved"
bindsym $mod+Print  exec grim -g "$(slurp)" "$HOME/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png" && notify-send "Screenshot saved"

# Volume (PipeWire, pactl-compatible)
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%   && notify-send -t 800 "Volume" "$(pactl get-sink-volume @DEFAULT_SINK@ | grep -Po '\d+(?=%)' | head -1)%"
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%   && notify-send -t 800 "Volume" "$(pactl get-sink-volume @DEFAULT_SINK@ | grep -Po '\d+(?=%)' | head -1)%"
bindsym XF86AudioMute        exec pactl set-sink-mute   @DEFAULT_SINK@ toggle

# Brightness
bindsym XF86MonBrightnessUp   exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

# ── Input ────────────────────────────────────────────────
input "type:keyboard" {
    xkb_layout "de"
    xkb_variant "nodeadkeys"
}

# ── Outputs ──────────────────────────────────────────────
output DP-1 {
    resolution 2560x1440
    position 0,0
}
output HDMI-A-3 {
    resolution 1920x1080
    position 2560,360
}

# ── Appearance ───────────────────────────────────────────
gaps inner 0
gaps outer 0
smart_gaps  off
smart_borders on

default_border          pixel 2
default_floating_border pixel 2
hide_edge_borders       smart

# Window colors — variables set by colors.sway include
#                        border      background  text        indicator   child_border
client.focused           $color4     $color4     $foreground $color4     $color4
client.focused_inactive  $background $color0     $color7     $color8     $background
client.unfocused         $background $background $color5     $color8     $background
client.urgent            $color1     $color1     $foreground $color1     $color1
client.placeholder       $color0     $background $foreground $background $color0

# ── Autostart ────────────────────────────────────────────
exec        nm-applet
exec        mako
exec        swaybg -i "$HOME/wallpapers/current" -m fill 2>/dev/null || true
exec        waybar
# -f/--daemonize dropped from swaylock calls below: it forks away from the
# invoking process before the lock surface's first frame is guaranteed to be
# rendered, which can leave the screen looking unlocked/transparent. swayidle
# already runs its commands as separate processes, so it isn't needed anyway.
exec        swayidle -w \
                timeout 3600 'swaylock' \
                timeout 3900 'swaymsg "output * dpms off"' resume 'swaymsg "output * dpms on"' \
                before-sleep 'swaylock'

# ── Floating rules ───────────────────────────────────────
for_window [app_id="pavucontrol"]           floating enable
for_window [class="Pavucontrol"]            floating enable
for_window [class="Lxappearance"]           floating enable
for_window [class="Nm-connection-editor"]   floating enable
for_window [title="File Transfer*"]         floating enable
for_window [app_id="swaynag"]               floating enable
